{
  "name": "sewer-frontend",
  "version": "2.0.0",
  "description": "QGIS‑like Sewer Asset Management for Mutare City Council",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron . --debug"
  },
  "author": "Mutare City Council",
  "license": "MIT",
  "dependencies": {
    "@turf/turf": "^7.1.0",
    "axios": "^1.6.2",
    "better-sqlite3": "^9.0.0",
    "dotenv": "^16.3.1",
    "electron": "^28.0.0",
    "electron-store": "^8.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.0",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "pg": "^8.11.0",
    "pdfjs-dist": "5.4.149",
    "shpjs": "^6.2.0"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.mutare.sewer",
    "productName": "Sewer Asset Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.map",
      "!node_modules/.bin",
      "node_modules/pdfjs-dist/build/pdf.worker.mjs",
      "plugins/leaflet.heat.js"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/mutare_logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/mutare_logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/mutare_logo.png"
    }
  }
}
