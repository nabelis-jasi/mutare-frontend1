{
  "name": "mutare-sewer-command-center",
  "version": "1.0.0",
  "description": "Local GIS, Analytics, and Job Log Desktop Application for Mutare City Council",
  "main": "main.js",
  "author": "Mutare Engineering",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "pg": "^8.11.3",
    "chart.js": "^4.4.1"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.mutare.sewergis",
    "productName": "Mutare Sewer GIS",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!node_modules/*",
      "node_modules/pg/**/*",
      "node_modules/electron-store/**/*"
    ]
  }
}
